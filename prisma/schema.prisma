generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AccountType {
  CHECKING
  TAX
  SAVINGS
  INVESTMENT
  CASH
  CREDIT
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
  INVESTMENT
  TAX
}

enum TransactionStatus {
  PENDING
  CLEARED
  PLANNED
}

enum TransactionOrigin {
  MANUAL
  IMPORTED
  SEEDED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
}

enum InvestmentTransactionType {
  BUY
  SELL
  DIVIDEND
  CONTRIBUTION
}

model User {
  id                     String                  @id @default(cuid())
  email                  String                  @unique
  name                   String
  currency               String                  @default("EUR")
  locale                 String                  @default("es-ES")
  country                String                  @default("ES")
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  accounts               Account[]
  categories             Category[]
  budgets                Budget[]
  investmentAssets       InvestmentAsset[]
  investmentTransactions InvestmentTransaction[]
  invoices               Invoice[]
  monthlySnapshots       MonthlySnapshot[]
  salaryProfiles         SalaryProfile[]
  settings               AppSetting?
  subcategories          Subcategory[]
  taxProvisions          TaxProvision[]
  transactions           Transaction[]
}

model Account {
  id                     String                  @id @default(cuid())
  userId                 String
  name                   String
  type                   AccountType
  currency               String                  @default("EUR")
  institution            String?
  description            String?
  isActive               Boolean                 @default(true)
  isTaxReserved          Boolean                 @default(false)
  openingBalance         Decimal                 @default(0) @db.Decimal(14, 2)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  user                   User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  outgoing               Transaction[]           @relation("fromAccount")
  incoming               Transaction[]           @relation("toAccount")
  investmentAssets       InvestmentAsset[]
  investmentTransactions InvestmentTransaction[]

  @@index([userId, type])
}

model Category {
  id            String          @id @default(cuid())
  userId        String
  name          String
  slug          String
  kind          TransactionType
  color         String?
  icon          String?
  sortOrder     Int             @default(0)
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  budgets       Budget[]
  subcategories Subcategory[]
  transactions  Transaction[]

  @@unique([userId, slug])
  @@index([userId, kind])
}

model Subcategory {
  id           String        @id @default(cuid())
  userId       String
  categoryId   String
  name         String
  slug         String
  color        String?
  sortOrder    Int           @default(0)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  category     Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([categoryId, slug])
  @@index([userId, categoryId])
}

model Transaction {
  id                String            @id @default(cuid())
  userId            String
  type              TransactionType
  accountId         String?
  transferAccountId String?
  categoryId        String?
  subcategoryId     String?
  date              DateTime
  amount            Decimal           @db.Decimal(14, 2)
  currency          String            @default("EUR")
  description       String
  merchant          String?
  notes             String?
  tags              String[]
  isRecurring       Boolean           @default(false)
  origin            TransactionOrigin @default(MANUAL)
  status            TransactionStatus @default(CLEARED)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  account           Account?          @relation("fromAccount", fields: [accountId], references: [id], onDelete: SetNull)
  transferAccount   Account?          @relation("toAccount", fields: [transferAccountId], references: [id], onDelete: SetNull)
  category          Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  subcategory       Subcategory?      @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([userId, type])
  @@index([accountId])
}

model Budget {
  id           String    @id @default(cuid())
  userId       String
  categoryId   String?
  month        DateTime
  amount       Decimal   @db.Decimal(14, 2)
  rollover     Boolean   @default(false)
  alertPercent Int       @default(80)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category     Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@unique([userId, categoryId, month])
  @@index([userId, month])
}

model Invoice {
  id                   String        @id @default(cuid())
  userId               String
  issueDate            DateTime
  dueDate              DateTime?
  paidDate             DateTime?
  clientName           String
  notes                String?
  status               InvoiceStatus @default(SENT)
  baseAmount           Decimal       @db.Decimal(14, 2)
  vatRate              Decimal       @db.Decimal(5, 4)
  withholdingRate      Decimal       @db.Decimal(5, 4)
  totalAmount          Decimal       @db.Decimal(14, 2)
  expectedBankAmount   Decimal       @db.Decimal(14, 2)
  vatAmount            Decimal       @db.Decimal(14, 2)
  withholdingAmount    Decimal       @db.Decimal(14, 2)
  estimatedIrpfRate    Decimal       @db.Decimal(5, 4)
  estimatedIrpfAmount  Decimal       @db.Decimal(14, 2)
  pendingIrpfProvision Decimal       @db.Decimal(14, 2)
  realNetAmount        Decimal       @db.Decimal(14, 2)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, issueDate])
  @@index([userId, status])
}

model TaxProvision {
  id            String   @id @default(cuid())
  userId        String
  month         DateTime
  vatAccrued    Decimal  @db.Decimal(14, 2)
  irpfWithheld  Decimal  @db.Decimal(14, 2)
  irpfEstimated Decimal  @db.Decimal(14, 2)
  irpfPending   Decimal  @db.Decimal(14, 2)
  freelancerFee Decimal  @db.Decimal(14, 2)
  availableNet  Decimal  @db.Decimal(14, 2)
  apparentCash  Decimal  @db.Decimal(14, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@index([userId, month])
}

model SalaryProfile {
  id            String    @id @default(cuid())
  userId        String
  employer      String
  grossAnnual   Decimal   @db.Decimal(14, 2)
  netMonthly    Decimal   @db.Decimal(14, 2)
  payPeriods    Int
  retentionRate Decimal?  @db.Decimal(5, 4)
  monthlyBonus  Decimal?  @db.Decimal(14, 2)
  notes         String?
  activeFrom    DateTime
  activeTo      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, activeFrom])
}

model InvestmentAsset {
  id           String                  @id @default(cuid())
  userId       String
  accountId    String?
  name         String
  ticker       String?
  assetType    String
  currency     String                  @default("EUR")
  units        Decimal                 @default(0) @db.Decimal(18, 6)
  averageCost  Decimal                 @default(0) @db.Decimal(14, 2)
  currentPrice Decimal                 @default(0) @db.Decimal(14, 2)
  currentValue Decimal                 @default(0) @db.Decimal(14, 2)
  notes        String?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  account      Account?                @relation(fields: [accountId], references: [id], onDelete: SetNull)
  transactions InvestmentTransaction[]

  @@index([userId, assetType])
}

model InvestmentTransaction {
  id          String                    @id @default(cuid())
  userId      String
  assetId     String
  accountId   String?
  type        InvestmentTransactionType
  tradeDate   DateTime
  units       Decimal                   @default(0) @db.Decimal(18, 6)
  price       Decimal                   @default(0) @db.Decimal(14, 2)
  fees        Decimal                   @default(0) @db.Decimal(14, 2)
  totalAmount Decimal                   @db.Decimal(14, 2)
  notes       String?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  user        User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset       InvestmentAsset           @relation(fields: [assetId], references: [id], onDelete: Cascade)
  account     Account?                  @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([userId, tradeDate])
}

model MonthlySnapshot {
  id                 String   @id @default(cuid())
  userId             String
  month              DateTime
  incomeTotal        Decimal  @db.Decimal(14, 2)
  expenseTotal       Decimal  @db.Decimal(14, 2)
  savingsTotal       Decimal  @db.Decimal(14, 2)
  investmentTotal    Decimal  @db.Decimal(14, 2)
  apparentCashflow   Decimal  @db.Decimal(14, 2)
  realCashflow       Decimal  @db.Decimal(14, 2)
  taxPending         Decimal  @db.Decimal(14, 2)
  netWorth           Decimal  @db.Decimal(14, 2)
  budgetConsumedRate Decimal  @db.Decimal(8, 4)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@index([userId, month])
}

model AppSetting {
  id                       String   @id @default(cuid())
  userId                   String   @unique
  country                  String   @default("ES")
  currency                 String   @default("EUR")
  budgetMonthStartDay      Int      @default(1)
  defaultVatRate           Decimal  @db.Decimal(5, 4)
  defaultWithholdingRate   Decimal  @db.Decimal(5, 4)
  effectiveIrpfRate        Decimal  @db.Decimal(5, 4)
  freelancerMonthlyFee     Decimal  @db.Decimal(14, 2)
  salaryNetMonthlyEstimate Decimal  @db.Decimal(14, 2)
  fiscalCalendarNotes      String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
